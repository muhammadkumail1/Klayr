# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_...   # Get free key at https://console.groq.com/

# ---------------------------------------------------------------------------
# Optional — missing keys use lower rate limits but still work
# ---------------------------------------------------------------------------
# Free key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Free key at https://ncbi.nlm.nih.gov/account — raises rate limit 3→10 req/sec
NCBI_API_KEY=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_scientist
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# App configuration
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
